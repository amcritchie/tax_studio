<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-extrabold text-heading"><%= @upload.filename %></h1>
    <p class="text-secondary text-sm mt-1 flex items-center gap-1.5">
      <% if @upload.payment_method&.logo.present? %>
        <img src="<%= @upload.payment_method.logo %>" alt="" class="w-4 h-4 object-contain">
      <% end %>
      <%= @upload.card_type_display %> &middot; Uploaded <%= @upload.created_at.strftime("%b %d, %Y") %>
    </p>
  </div>
  <div class="flex items-center gap-3">
    <% if @upload.pending? %>
      <%= button_to "Process File", process_file_expense_upload_path(@upload.slug), method: :post, class: "btn btn-primary btn-sm" %>
    <% elsif @upload.processed? %>
      <%= button_to "Run AI Evaluation", evaluate_expense_upload_path(@upload.slug), method: :post, class: "btn btn-primary btn-sm" %>
    <% end %>
    <%= button_to "Delete", expense_upload_path(@upload.slug), method: :delete, class: "btn btn-danger btn-sm",
        data: { turbo_confirm: "Delete this upload and all its transactions?" } %>
  </div>
</div>

<%# Evaluation Progress Bar %>
<% if @upload.evaluating? %>
<% eval_total = @upload.expense_transactions.count %>
<% eval_processed = @upload.expense_transactions.where.not(status: "unreviewed").count %>
<% eval_progress = { processed: eval_processed, total: eval_total } %>
<div x-data="evaluationProgress('<%= @upload.slug %>', <%= eval_progress.to_json %>)" class="card p-5 mb-6">
  <div class="flex items-center gap-3 mb-3">
    <span class="label-upper">AI Evaluation</span>
    <span class="badge bg-primary/10 text-primary border-primary/30">
      <span class="inline-block w-2 h-2 rounded-full bg-primary animate-pulse mr-1.5"></span>
      Evaluating
    </span>
  </div>

  <%# Error state %>
  <template x-if="error">
    <div class="p-3 rounded-lg bg-red-500/10 border border-red-500/30 text-sm">
      <p class="font-bold text-red-400 mb-1">Evaluation Error</p>
      <p class="text-red-300" x-text="error"></p>
      <p class="text-muted text-xs mt-2">Refreshing in 3 seconds...</p>
    </div>
  </template>

  <%# Progress state %>
  <template x-if="!error">
    <div>
      <div class="flex items-center justify-between text-sm mb-2">
        <span class="text-secondary" x-text="statusText">Connecting...</span>
        <span class="text-heading font-mono font-bold" x-text="percentText">0%</span>
      </div>
      <div class="w-full h-3 rounded-full bg-surface-alt overflow-hidden">
        <div class="h-full rounded-full transition-all duration-500 ease-out"
             :style="'width: ' + percent + '%; background-color: var(--color-cta)'">
        </div>
      </div>
    </div>
  </template>
</div>
<% end %>

<%# Status + Summary %>
<div class="card p-5 mb-6">
  <div class="flex items-center gap-4 mb-4">
    <span class="label-upper">Status</span>
    <% case @upload.status %>
    <% when "pending" %>
      <span class="badge bg-yellow-500/10 text-yellow-500 border-yellow-500/30">Pending</span>
    <% when "processed" %>
      <span class="badge bg-blue-500/10 text-blue-500 border-blue-500/30">Processed</span>
    <% when "evaluating" %>
      <span class="badge bg-primary/10 text-primary border-primary/30">Evaluating...</span>
    <% when "evaluated" %>
      <span class="badge bg-emerald-500/10 text-emerald-500 border-emerald-500/30">Evaluated</span>
    <% end %>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-6 gap-4 text-sm">
    <div>
      <p class="text-muted">Transactions</p>
      <p class="text-heading font-bold text-lg"><%= @upload.transaction_count %></p>
    </div>
    <div>
      <p class="text-muted">Unique Transactions</p>
      <p class="text-heading font-bold text-lg"><%= @upload.unique_transactions %></p>
    </div>
    <div>
      <p class="text-muted">Credits Skipped</p>
      <p class="text-heading font-bold text-lg"><%= @upload.credits_skipped %></p>
    </div>
    <% if @upload.evaluated? %>
      <div>
        <p class="text-muted">Needs Review</p>
        <p class="text-heading font-bold text-lg"><%= @upload.expense_transactions.needs_review.count %></p>
      </div>
      <div>
        <p class="text-muted">Reviewed</p>
        <p class="text-heading font-bold text-lg"><%= @upload.expense_transactions.reviewed.count %></p>
      </div>
    <% end %>
  </div>

  <% if @upload.processing_summary.present? && @upload.processing_summary["errors"].present? %>
    <div class="mt-4 p-3 rounded-lg bg-red-500/10 border border-red-500/30 text-sm">
      <p class="font-bold text-red-400 mb-1">Processing Errors:</p>
      <ul class="text-red-300 space-y-1">
        <% @upload.processing_summary["errors"].each do |error| %>
          <li><%= error %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% skipped = @upload.processing_summary&.dig("skipped") %>
  <% if skipped.present? %>
    <% credits = skipped.select { |s| s["reason"] == "credit" } %>
    <div class="mt-4" x-data="{ showSkipped: false }">
      <button @click="showSkipped = !showSkipped" class="text-sm text-secondary hover:text-heading transition flex items-center gap-1">
        <svg class="w-4 h-4 transition-transform" :class="showSkipped && 'rotate-90'" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        View skipped credits (<%= credits.size %>)
      </button>
      <div x-show="showSkipped" x-collapse.duration.200ms class="mt-3">
        <% if credits.any? %>
          <p class="label-upper mb-2">Credits (<%= credits.size %>)</p>
          <div class="overflow-x-auto">
            <table class="w-full text-xs">
              <thead>
                <tr class="text-muted text-left border-b border-subtle">
                  <th class="py-1.5 pr-4 font-medium">Date</th>
                  <th class="py-1.5 pr-4 font-medium">Description</th>
                  <th class="py-1.5 font-medium text-right">Amount</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-subtle">
                <% credits.each do |s| %>
                  <tr>
                    <td class="py-1.5 pr-4 text-secondary"><%= s["date"] %></td>
                    <td class="py-1.5 pr-4 text-heading"><%= truncate(s["description"].to_s, length: 60) %></td>
                    <td class="py-1.5 font-mono text-heading text-right">$<%= '%.2f' % ((s["amount_cents"] || 0) / 100.0) %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<%# Transactions Table %>
<% if @transactions.any? %>
  <% vendor_slugs = @transactions.reject(&:excluded).group_by { |t| (t.vendor || t.raw_description).to_s.downcase.strip }.transform_values { |txns| txns.map(&:slug) } %>
  <% nr_by_vendor = @transactions.select { |t| t.needs_review? && !t.excluded }.group_by { |t| (t.vendor || t.raw_description).to_s.downcase.strip }.transform_values { |txns| txns.map(&:slug) } %>
  <div class="card overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-surface-alt text-muted text-left">
          <th class="px-4 py-3 font-medium">Date</th>
          <th class="px-4 py-3 font-medium">Description</th>
          <th class="px-4 py-3 font-medium text-right">Amount</th>
          <th class="px-4 py-3 font-medium">Status</th>
          <th class="px-4 py-3 font-medium">Category</th>
          <th class="px-4 py-3 font-medium">Account</th>
          <th class="px-4 py-3 font-medium"></th>
        </tr>
      </thead>
      <% @transactions.each do |txn| %>
        <% if txn.needs_review? && !txn.excluded %>
          <% vendor_key = (txn.vendor || txn.raw_description).to_s.downcase.strip %>
          <% similar_nr_slugs = ((nr_by_vendor[vendor_key] || []) - [txn.slug]) %>
          <tbody x-data="inlineReview(<%= { slug: txn.slug, vendor: txn.vendor || truncate(txn.raw_description, length: 50), category: txn.category.to_s, account: txn.account.to_s, categoryDisplay: txn.category_display.to_s, accountDisplay: txn.account_display.to_s, similarSlugs: similar_nr_slugs }.to_json %>)"
                 @exclude-toggled.window="if ($event.detail.slug === '<%= txn.slug %>') { excluded = $event.detail.excluded; if ($event.detail.excluded) { resolved = true; resolvedBadge = '<span class=\'badge bg-gray-500/10 text-gray-400 border-gray-500/30\'>Excluded</span>'; open = false; } }"
                 @review-approved.window="if ($event.detail.slug === '<%= txn.slug %>') { category = $event.detail.category; account = $event.detail.account; categoryDisplay = $event.detail.categoryDisplay; accountDisplay = $event.detail.accountDisplay; resolved = true; resolvedBadge = $event.detail.badge; open = false; }"
                 class="divide-y divide-subtle border-t border-subtle">
            <tr class="hover:bg-surface-alt/50 transition">
              <td class="px-4 py-3 text-secondary"><%= txn.transaction_date.strftime("%m/%d/%y") %></td>
              <td class="px-4 py-3">
                <div class="flex items-center gap-1.5">
                  <%= link_to expense_transaction_path(txn.slug), class: "text-heading hover:text-primary transition" do %>
                    <span class="font-medium"><%= txn.vendor || truncate(txn.raw_description, length: 50) %></span>
                  <% end %>
                  <a href="https://www.google.com/search?q=<%= ERB::Util.url_encode(txn.raw_description) %>" target="_blank" rel="noopener" class="text-secondary hover:text-primary shrink-0" title="Search Google">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" /></svg>
                  </a>
                </div>
              </td>
              <td class="px-4 py-3 text-right font-mono text-heading"><%= txn.formatted_amount %></td>
              <td class="px-4 py-3">
                <template x-if="resolved">
                  <span x-html="resolvedBadge"></span>
                </template>
                <template x-if="!resolved">
                  <button @click="open = !open" class="badge bg-orange-500/10 text-orange-500 border-orange-500/30 cursor-pointer hover:bg-orange-500/20 transition">
                    Needs Review
                    <svg class="w-3 h-3 ml-1 inline transition-transform" :class="open && 'rotate-180'" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                  </button>
                </template>
              </td>
              <td class="px-4 py-3 text-secondary" x-text="categoryDisplay"><%= txn.category_display %></td>
              <td class="px-4 py-3 text-secondary" x-text="accountDisplay"><%= txn.account_display %></td>
              <td class="px-4 py-3">
                <%= render "expense_transactions/exclude_toggle", txn: txn %>
              </td>
            </tr>
            <tr x-show="open" x-collapse.duration.200ms class="bg-surface-alt/30">
              <td colspan="7" class="px-4 py-4">
                <%# Error message %>
                <template x-if="errorMsg">
                  <div class="mb-3 p-2 rounded bg-red-500/10 border border-red-500/30 text-red-400 text-xs" x-text="errorMsg"></div>
                </template>

                <% if txn.ai_question.present? %>
                  <div class="mb-3 p-3 rounded-lg bg-orange-500/5 border border-orange-500/20">
                    <p class="text-xs text-orange-400 font-bold mb-1">AI Question</p>
                    <p class="text-sm text-heading mb-2"><%= txn.ai_question %></p>
                    <% if txn.user_answer.blank? %>
                      <div class="flex gap-2">
                        <input type="text" x-model="userAnswer" placeholder="Your answer..." class="input-field text-xs flex-1 py-1.5">
                        <button @click="submitAnswer()" :disabled="loading || !userAnswer" class="btn btn-primary btn-sm text-xs">
                          <span x-show="!loading">Submit</span>
                          <span x-show="loading" class="flex items-center gap-1">
                            <svg class="animate-spin w-3 h-3" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                            Saving
                          </span>
                        </button>
                      </div>
                    <% else %>
                      <p class="text-xs text-muted">Your answer: <span class="text-heading"><%= txn.user_answer %></span></p>
                    <% end %>
                  </div>
                <% end %>

                <div class="flex flex-wrap items-end gap-3">
                  <div>
                    <label class="text-xs text-muted block mb-1">Category</label>
                    <select x-model="category" class="input-field text-xs py-1.5 pr-8">
                      <option value="">Select...</option>
                      <% ExpenseTransaction::CATEGORIES.each do |k, v| %>
                        <option value="<%= k %>" <%= 'selected' if txn.category == k %>><%= v %></option>
                      <% end %>
                    </select>
                  </div>
                  <div>
                    <label class="text-xs text-muted block mb-1">Account</label>
                    <select x-model="account" class="input-field text-xs py-1.5 pr-8">
                      <option value="">Select...</option>
                      <% ExpenseTransaction::ACCOUNTS.each do |k, v| %>
                        <option value="<%= k %>" <%= 'selected' if txn.account == k %>><%= v %></option>
                      <% end %>
                    </select>
                  </div>
                  <template x-if="similarSlugs.length > 0">
                    <label class="flex items-center gap-1.5 text-xs text-secondary cursor-pointer self-end pb-1.5">
                      <input type="checkbox" x-model="applyToSimilar" class="rounded border-strong bg-surface-alt text-primary focus:ring-primary w-3.5 h-3.5">
                      Include <span class="font-bold text-heading" x-text="similarSlugs.length"></span> matching
                    </label>
                  </template>
                  <button @click="approve()" :disabled="loading" class="btn btn-primary btn-sm text-xs">
                    <span x-show="!loading">Approve</span>
                    <span x-show="loading" class="flex items-center gap-1">
                      <svg class="animate-spin w-3 h-3" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                      Saving
                    </span>
                  </button>
                  <button @click="exclude()" :disabled="loading" class="btn btn-outline btn-sm text-xs">Exclude</button>
                  <button @click="open = false" class="btn btn-outline btn-sm text-xs text-muted">Cancel</button>
                </div>
              </td>
            </tr>
          </tbody>
        <% else %>
          <tbody class="divide-y divide-subtle border-t border-subtle">
            <tr x-data="{ excluded: <%= txn.excluded %> }"
                @exclude-toggled.window="if ($event.detail.slug === '<%= txn.slug %>') { excluded = $event.detail.excluded }"
                class="hover:bg-surface-alt/50 transition" :class="excluded && 'opacity-50'">
              <td class="px-4 py-3 text-secondary"><%= txn.transaction_date.strftime("%m/%d/%y") %></td>
              <td class="px-4 py-3">
                <div class="flex items-center gap-1.5">
                  <%= link_to expense_transaction_path(txn.slug), class: "text-heading hover:text-primary transition" do %>
                    <span class="font-medium"><%= txn.vendor || truncate(txn.raw_description, length: 50) %></span>
                  <% end %>
                  <a href="https://www.google.com/search?q=<%= ERB::Util.url_encode(txn.raw_description) %>" target="_blank" rel="noopener" class="text-secondary hover:text-primary shrink-0" title="Search Google">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" /></svg>
                  </a>
                </div>
              </td>
              <td class="px-4 py-3 text-right font-mono text-heading"><%= txn.formatted_amount %></td>
              <td class="px-4 py-3">
                <%= render "expense_transactions/status_badge", txn: txn %>
              </td>
              <td class="px-4 py-3 text-secondary"><%= txn.category_display %></td>
              <td class="px-4 py-3 text-secondary"><%= txn.account_display %></td>
              <td class="px-4 py-3 flex items-center gap-1">
                <% if txn.status.in?(%w[reviewed classified]) %>
                  <%= button_to re_evaluate_expense_transaction_path(txn.slug), method: :post, class: "text-secondary hover:text-primary transition shrink-0", title: "Re-evaluate with AI", data: { turbo_confirm: "Re-evaluate this transaction with AI?" } do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.992 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182" /></svg>
                  <% end %>
                <% end %>
                <%= render "expense_transactions/exclude_toggle", txn: txn %>
              </td>
            </tr>
          </tbody>
        <% end %>
      <% end %>
    </table>
  </div>

  <script>
    document.addEventListener('alpine:init', () => {
      Alpine.data('inlineReview', (config) => ({
        open: false,
        loading: false,
        resolved: false,
        resolvedBadge: '',
        errorMsg: '',
        userAnswer: '',
        excluded: false,
        category: config.category,
        account: config.account,
        categoryDisplay: config.categoryDisplay,
        accountDisplay: config.accountDisplay,
        applyToSimilar: false,
        similarSlugs: config.similarSlugs || [],

        get csrfToken() {
          return document.querySelector('meta[name="csrf-token"]')?.content;
        },

        async approve() {
          this.loading = true;
          this.errorMsg = '';
          try {
            const body = { expense_transaction: {} };
            if (this.category) body.expense_transaction.category = this.category;
            if (this.account) body.expense_transaction.account = this.account;
            const res = await fetch(`/transactions/${config.slug}.json`, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': this.csrfToken },
              body: JSON.stringify(body)
            });
            if (!res.ok) throw new Error((await res.json()).error || 'Update failed');
            const data = await res.json();
            this.applyResult(data);

            if (this.applyToSimilar && this.similarSlugs.length) {
              const badge = data.business_expense
                ? '<span class="badge bg-emerald-500/10 text-emerald-500 border-emerald-500/30">Business</span>'
                : '<span class="badge bg-gray-500/10 text-gray-400 border-gray-500/30">Personal</span>';
              for (const slug of this.similarSlugs) {
                try {
                  await fetch(`/transactions/${slug}.json`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': this.csrfToken },
                    body: JSON.stringify(body)
                  });
                  window.dispatchEvent(new CustomEvent('review-approved', {
                    detail: { slug, badge, category: this.category, account: this.account, categoryDisplay: this.categoryDisplay, accountDisplay: this.accountDisplay }
                  }));
                } catch (e) { /* continue batch */ }
              }
            }
          } catch (e) {
            this.errorMsg = e.message;
          } finally {
            this.loading = false;
          }
        },

        async submitAnswer() {
          this.loading = true;
          this.errorMsg = '';
          try {
            const res = await fetch(`/transactions/${config.slug}/answer_review.json`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': this.csrfToken },
              body: JSON.stringify({ user_answer: this.userAnswer })
            });
            if (!res.ok) throw new Error((await res.json()).error || 'Review failed');
            const data = await res.json();
            this.applyResult(data);
          } catch (e) {
            this.errorMsg = e.message;
          } finally {
            this.loading = false;
          }
        },

        exclude() {
          window.dispatchEvent(new CustomEvent('open-exclude-modal', {
            detail: { slug: config.slug, vendor: config.vendor, excluded: false }
          }));
          this.open = false;
        },

        applyResult(data) {
          this.categoryDisplay = data.category_display || '';
          this.accountDisplay = data.account_display || '';
          this.category = data.category || '';
          this.account = data.account || '';
          this.resolved = true;
          if (data.business_expense) {
            this.resolvedBadge = '<span class="badge bg-emerald-500/10 text-emerald-500 border-emerald-500/30">Business</span>';
          } else {
            this.resolvedBadge = '<span class="badge bg-gray-500/10 text-gray-400 border-gray-500/30">Personal</span>';
          }
          this.open = false;
        }
      }));
    });
  </script>
<% else %>
  <div class="empty-state">
    <p class="text-secondary">No transactions yet. Process the file to extract transactions.</p>
  </div>
<% end %>

<%= render "expense_transactions/exclude_modal", vendor_slugs: (defined?(vendor_slugs) ? vendor_slugs : nil) %>
