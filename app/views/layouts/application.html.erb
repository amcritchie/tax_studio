<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Tax Studio" %></title>
    <%= render "layouts/studio/head" %>
  </head>

  <body x-data class="bg-page text-body min-h-screen" :class="{ 'dev-mode': $store.devMode }">
    <%= render "components/dev_banner" %>
    <%= render "layouts/navbar" %>

    <% if content_for?(:full_width) %>
      <div class="max-w-7xl mx-auto px-4">
        <%= render "layouts/studio/flash" %>
      </div>
      <%= yield %>
    <% else %>
      <div class="max-w-7xl mx-auto px-4 py-6">
        <%= render "layouts/studio/flash" %>
        <%= yield %>
      </div>
    <% end %>
  </body>
</html>
