<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-extrabold text-heading"><%= @year %> Tax Report</h1>
    <p class="text-secondary text-sm mt-1">Business expense summary for tax filing</p>
  </div>
  <div class="flex items-center gap-3">
    <%= link_to "All Transactions", expense_transactions_path, class: "btn btn-outline btn-sm" %>
    <%= link_to "Summary", summary_expense_transactions_path, class: "btn btn-outline btn-sm" %>
    <%= link_to "Export CSV", export_expense_transactions_path, class: "btn btn-primary btn-sm" %>
  </div>
</div>

<%# Warnings %>
<% if @needs_review.count > 0 || @unreviewed.count > 0 %>
  <div class="p-4 rounded-lg bg-orange-500/10 border border-orange-500/30 mb-6">
    <p class="font-bold text-orange-400 text-sm mb-1">Incomplete Data</p>
    <ul class="text-orange-300 text-sm space-y-1">
      <% if @unreviewed.count > 0 %>
        <li><%= @unreviewed.count %> transactions have not been evaluated by AI</li>
      <% end %>
      <% if @needs_review.count > 0 %>
        <li><%= link_to "#{@needs_review.count} transactions need your review", expense_transactions_path(status: "needs_review"), class: "underline hover:text-orange-200" %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%# Top Stats %>
<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
  <div class="card p-5">
    <p class="label-upper mb-1">Total Business Deductions</p>
    <p class="text-heading font-extrabold text-2xl">$<%= '%.2f' % (@total_business_cents / 100.0) %></p>
  </div>
  <div class="card p-5">
    <p class="label-upper mb-1">Business Transactions</p>
    <p class="text-heading font-extrabold text-2xl"><%= @business.count %></p>
  </div>
  <div class="card p-5">
    <p class="label-upper mb-1">Total Spend (<%= @year %>)</p>
    <p class="text-heading font-extrabold text-2xl">$<%= '%.2f' % (@total_all_cents / 100.0) %></p>
  </div>
  <div class="card p-5">
    <p class="label-upper mb-1">Business %</p>
    <p class="text-heading font-extrabold text-2xl">
      <% if @total_all_cents > 0 %>
        <%= '%.1f' % ((@total_business_cents.to_f / @total_all_cents) * 100) %>%
      <% else %>
        0%
      <% end %>
    </p>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
  <%# By Deduction Type — most important for taxes %>
  <div class="card p-5">
    <h3 class="label-upper mb-4">By Deduction Type</h3>
    <% if @by_deduction_type.any? %>
      <div class="space-y-3">
        <% @by_deduction_type.each do |type, cents| %>
          <div class="flex items-center justify-between text-sm">
            <span class="text-heading"><%= ExpenseTransaction::DEDUCTION_TYPES[type] || type&.titleize || "Unclassified" %></span>
            <span class="font-mono text-heading font-bold">$<%= '%.2f' % (cents / 100.0) %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-muted text-sm">No data yet.</p>
    <% end %>
  </div>

  <%# By Account %>
  <div class="card p-5">
    <h3 class="label-upper mb-4">By Business Account</h3>
    <% if @by_account.any? %>
      <div class="space-y-3">
        <% @by_account.each do |account, cents| %>
          <div class="flex items-center justify-between text-sm">
            <span class="text-heading"><%= ExpenseTransaction::ACCOUNTS[account] || account&.titleize || "Unassigned" %></span>
            <span class="font-mono text-heading font-bold">$<%= '%.2f' % (cents / 100.0) %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-muted text-sm">No data yet.</p>
    <% end %>
  </div>
</div>

<%# By Category — full breakdown %>
<div class="card p-5 mb-6">
  <h3 class="label-upper mb-4">Deductions by Category</h3>
  <% if @by_category.any? %>
    <div class="space-y-2">
      <% @by_category.each do |category, cents| %>
        <div class="flex items-center justify-between text-sm">
          <div class="flex items-center gap-3">
            <span class="text-heading"><%= ExpenseTransaction::CATEGORIES[category] || category&.titleize || "Uncategorized" %></span>
            <span class="text-muted text-xs"><%= @business.where(category: category).count %> txns</span>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-32 h-2 rounded-full bg-surface-alt overflow-hidden">
              <div class="h-full rounded-full" style="background-color: var(--color-cta); width: <%= @total_business_cents > 0 ? (cents.to_f / @total_business_cents * 100).round(1) : 0 %>%"></div>
            </div>
            <span class="font-mono text-heading font-bold w-24 text-right">$<%= '%.2f' % (cents / 100.0) %></span>
          </div>
        </div>
      <% end %>
    </div>
    <div class="mt-4 pt-4 border-t border-subtle flex items-center justify-between text-sm font-bold">
      <span class="text-heading">Total</span>
      <span class="font-mono text-heading">$<%= '%.2f' % (@total_business_cents / 100.0) %></span>
    </div>
  <% else %>
    <p class="text-muted text-sm">No business expenses found for <%= @year %>.</p>
  <% end %>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <%# By Month %>
  <div class="card p-5">
    <h3 class="label-upper mb-4">Monthly Breakdown</h3>
    <% if @by_month.any? %>
      <div class="space-y-2">
        <% @by_month.each do |month, cents| %>
          <div class="flex items-center justify-between text-sm">
            <span class="text-heading"><%= Date.parse("#{month}-01").strftime("%B %Y") %></span>
            <span class="font-mono text-heading">$<%= '%.2f' % (cents / 100.0) %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-muted text-sm">No data yet.</p>
    <% end %>
  </div>

  <%# By Card %>
  <div class="card p-5">
    <h3 class="label-upper mb-4">By Payment Method</h3>
    <% if @by_card.any? %>
      <div class="space-y-2">
        <% @by_card.each do |card, cents| %>
          <div class="flex items-center justify-between text-sm">
            <span class="text-heading"><%= PaymentMethod.find_by(parser_key: card)&.name || card&.titleize || "Unknown" %></span>
            <span class="font-mono text-heading">$<%= '%.2f' % (cents / 100.0) %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-muted text-sm">No data yet.</p>
    <% end %>
  </div>
</div>
